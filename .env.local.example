# Supabase
NEXT_PUBLIC_SUPABASE_URL=your_supabase_url
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key

# Solana — RPC provider pool (server-only, never exposed to the browser).
# Primary is required in production once any tier var below is set.
# Leaving all three unset falls back to NEXT_PUBLIC_SOLANA_RPC_URL (transitional — removed in PR 5).
SOLANA_RPC_PRIMARY_URL=
# Optional but strongly recommended: second paid provider for failover.
SOLANA_RPC_SECONDARY_URL=
# Optional: defaults to https://api.mainnet-beta.solana.com when unset.
SOLANA_RPC_FALLBACK_URL=

# Feature flag: Enable 2-of-N consensus verifier for critical reads
# (Organic ID grant, vote snapshots, treasury balance, donation tx
# confirmation). Off by default during rollout — the code is merged
# but not enforcing. Enable per-env after observing that baseline
# disagreement rate is zero.
# See docs/superpowers/specs/2026-04-22-rpc-resilience-design.md §7, §12.
SOLANA_RPC_CONSENSUS_ENABLED=false

# Solana — browser-facing config (wallet adapter reads NEXT_PUBLIC_SOLANA_RPC_URL).
# Transitional: also read by server code as a fallback until PR 5 retires it.
# In PR 5, rotate this to a domain-restricted wallet-adapter-only key.
NEXT_PUBLIC_SOLANA_RPC_URL=https://api.mainnet-beta.solana.com
NEXT_PUBLIC_SOLANA_NETWORK=mainnet-beta
NEXT_PUBLIC_ORG_TOKEN_MINT=DuXugm4oTXrGDopgxgudyhboaf6uUg1GVbJ6jk6qbonk

# App
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_APP_DOMAIN=app.organic-bonk.fun
NEXT_TELEMETRY_DISABLED=1

# Twitter/X OAuth
TWITTER_CLIENT_ID=your_twitter_client_id
TWITTER_CLIENT_SECRET=your_twitter_client_secret
TWITTER_REDIRECT_URI=http://localhost:3000/api/twitter/link/callback
# Optional alias (supported for compatibility)
TWITTER_CALLBACK_URL=http://localhost:3000/api/twitter/link/callback
TWITTER_OAUTH_SCOPE="tweet.read users.read like.read offline.access"
# Optional: auto | basic | client_secret_post | none
TWITTER_TOKEN_AUTH_METHOD=auto
TWITTER_TOKEN_ENCRYPTION_KEY=generate_a_32_byte_hex_or_base64_key

# Admin
ADMIN_EMAIL=organic_community@proton.me

# Analytics (Optional)
NEXT_PUBLIC_PLAUSIBLE_DOMAIN=app.organic-bonk.fun

# Error Monitoring (Optional)
SENTRY_DSN=your_sentry_dsn
NEXT_PUBLIC_SENTRY_DSN=your_public_sentry_dsn
SENTRY_ENVIRONMENT=development
SENTRY_TRACES_SAMPLE_RATE=0.1
NEXT_PUBLIC_SENTRY_TRACES_SAMPLE_RATE=0.1
SENTRY_PROFILES_SAMPLE_RATE=0.0
SENTRY_ORG=
SENTRY_PROJECT=
SENTRY_AUTH_TOKEN=

# Upstash Redis (Optional distributed rate limiting)
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# Rate Limiting (Optional local override)
DISABLE_RATE_LIMIT=false
ENABLE_RATE_LIMIT_NON_VERCEL=false

# Vercel Cron (required for market snapshot warm refresh endpoint)
CRON_SECRET=

# Translation (DeepL Free — https://www.deepl.com/pro-api)
DEEPL_API_KEY=
