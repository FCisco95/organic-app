{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "framework": "nextjs",
  "buildCommand": "npm run build",
  "regions": ["iad1"],
  "git": {
    "deploymentEnabled": {
      "main": true,
      "phase/*": true,
      "feat/*": true,
      "fix/*": true,
      "chore/*": false,
      "docs/*": false,
      "claude/*": false
    }
  },
  "crons": [
    {
      "path": "/api/internal/ai/governance-summary/generate",
      "schedule": "0 8 * * *"
    },
    {
      "path": "/api/internal/cron/sprint-summary",
      "schedule": "0 6 * * *"
    }
  ]
}
