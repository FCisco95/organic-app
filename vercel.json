{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "framework": "nextjs",
  "buildCommand": "npm run build",
  "regions": ["iad1"],
  "crons": [
    {
      "path": "/api/internal/ai/governance-summary/generate",
      "schedule": "0 8 * * *"
    },
    {
      "path": "/api/internal/engagement/poll",
      "schedule": "*/15 * * * *"
    },
    {
      "path": "/api/internal/engagement/appeals-sweep",
      "schedule": "0 * * * *"
    }
  ]
}
